{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "M記",
  "version": "0.1.0",
  "identifier": "com.bxyz.markdown-press",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http: https: blob: asset:; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval' blob: asset:; worker-src 'self' blob: asset:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http: https:; font-src 'self' data: blob: asset:; frame-src 'self' blob: asset:; object-src 'self' blob: asset:; media-src 'self' blob: asset: http: https:;"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources": "./resources"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Yunz93/markdown-press/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZEMEVEREM2QTJGQTYxQUYKUldTdllmcWl4dDBPYlhXY3l5dGdtNHVLYWVNWjFjRTQ5OFBqSSt0d3g2eWZjNkNGdHNEK05ZR2UK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
